# Padel Club - Production Environment Variables
# Copy this file to .env.production and fill in your actual values
# DO NOT commit this file to git - add it to .gitignore

# ==========================================
# GENERAL CONFIGURATION
# ==========================================
APP_URL=https://padel.example.com
NODE_ENV=production

# ==========================================
# DATABASE
# ==========================================
# Use your production database connection string
# Examples:
#   PostgreSQL: postgresql://user:password@host:5432/dbname
#   Prisma Accelerate: prisma+postgres://api_key@accelerate.prisma-data.net/?api_key=...
DATABASE_URL=your_production_database_url_here

# ==========================================
# NEXTAUTH CONFIGURATION
# ==========================================
# Generate a secure secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=your_secure_random_secret_here_at_least_32_chars
NEXTAUTH_URL=https://padel.example.com

# ==========================================
# OAUTH PROVIDERS (Optional)
# ==========================================
# Get credentials from:
# Google: https://console.cloud.google.com/
# Facebook: https://developers.facebook.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# ==========================================
# EMAIL SERVICE - RESEND
# ==========================================
# Get API key from: https://resend.com/
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=noreply@padel.example.com

# ==========================================
# PAYMENT GATEWAY - PAYMOB
# ==========================================
# Get credentials from: https://paymob.com/
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_INTEGRATION_ID=your_card_integration_id
PAYMOB_IFRAME_ID=your_iframe_id
PAYMOB_HMAC_SECRET=your_hmac_secret_for_webhook_verification
CURRENCY=EGP

# ==========================================
# SECURITY NOTES
# ==========================================
# 1. Never commit this file to git
# 2. Use strong, random secrets (min 32 characters)
# 3. Keep API keys confidential - rotate them regularly
# 4. Use different credentials for dev/staging/production
# 5. Enable two-factor authentication on service accounts
